// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// NextAuth.js Models
// https://next-auth.js.org/adapters/prisma

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  
  // App-specific fields
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  plan          String    @default("free") // free, starter, pro
  desktopTokens DesktopToken[]
  devices       DesktopDevice[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Desktop app tokens for Tauri
model DesktopToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Track active devices for license limits
model DesktopDevice {
  id        String   @id @default(cuid())
  userId    String
  machineId String
  name      String?
  accessToken String @unique @default(cuid()) // Persistent session token
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, machineId])
}

model Waitlist {
  id              String   @id @default(cuid())
  email           String   @unique
  gpu             String?
  weddingsPerYear String?
  createdAt       DateTime @default(now())
}

// ----------------- OWNER DASHBOARD MODELS ----------------- //

// Core Owner Model for Fingerprint Auth
model OwnerFingerprint {
  id        String   @id @default(cuid())
  email     String   @unique
  hash      String   @unique
  isOwner   Boolean  @default(false)
  createdAt DateTime @default(now())
  lastSeen  DateTime @default(now())
}

// Group Chat Channels for Autonomous KiloClaws
model ClawChannel {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  themeColor  String   @default("gray")
  messages    ClawMessage[]
  createdAt   DateTime @default(now())
}

// Messages within a KiloClaw Channel
model ClawMessage {
  id          String   @id @default(cuid())
  channelId   String
  channel     ClawChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  agentName   String   // e.g., 'KiloClaw Alpha (Code)' or 'Owner'
  content     String   @db.Text
  isOwner     Boolean  @default(false) // True if sent by Aiden
  createdAt   DateTime @default(now())
}

// Dynamic Pipelines (Marketing, Code, etc.)
model Pipeline {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  color       String   // e.g., 'emerald', 'coral', 'indigo'
  order       Int      @default(0)
  isArchived  Boolean  @default(false)
  outputs     ClawOutput[]
  createdAt   DateTime @default(now())
}

// Intelligence Feed Outputs from KiloClaw
model ClawOutput {
  id              String   @id @default(cuid())
  pipelineId      String
  pipeline        Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  
  // Content & Trace
  content         String   @db.Text
  agentName       String   // e.g., 'Content Agent v3.2'
  confidence      Float    // 0 to 100
  predictionScore Float    // AI Prioritization score 0-100
  
  // Status and Meta
  status          String   @default("DRAFT") // DRAFT (Yellow), ACTION_NEEDED (Red), APPROVED (Green), PUBLISHED (Blue)
  suggestedAction String?  // e.g., 'Copy Full Spec', 'Deploy 42'
  metaData        Json?    // Optional JSON for A/B testing stats, code diffs, etc.
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ----------------- MOCKED STATS PROVISIONING ----------------- //
model Payment {
  id        String   @id @default(cuid())
  userId    String
  amount    Float
  status    String
  createdAt DateTime @default(now())
}

model Project {
  id            String   @id @default(cuid())
  userId        String
  weddingsCount Int      @default(1)
  timeSavedHrs  Float    @default(0.0)
  createdAt     DateTime @default(now())
}
